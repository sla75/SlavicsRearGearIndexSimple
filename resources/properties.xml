<resources xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">

    <properties>
        <property id="property_version" type="string">0.0.0</property>
        <property id="property_showteeth" type="boolean">false</property>
    </properties>

    <settings>
        <setting propertyKey="@Properties.property_version" title="@Strings.property_version_title">
            <settingConfig type="alphaNumeric" readonly="true"/>
        </setting>

        <setting propertyKey="@Properties.property_showteeth" title="@Strings.property_showteeth_title">
            <settingConfig type="boolean" required="true" />
        </setting>
    </settings>
</resources>
